# Telegram bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Google AI Studio API key for Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Group chat ID for announcements (use /chatid in the group to get this)
GROUP_CHAT_ID=

# Forum topic ID for announcements (use /chatid inside the Duck Hunt topic)
# Leave empty to post in General (not recommended for forum groups)
GROUP_TOPIC_ID=

# Admin user ID for manual reviews and admin commands (DM the bot and run /chatid)
ADMIN_USER_ID=

# Total number of ducks hidden (default 100)
TOTAL_DUCKS=100

# Gemini model for image verification
GEMINI_MODEL=gemini-2.0-flash

# Path to SQLite database file
DB_PATH=ducks.db

# Folder for admin hiding-spot reference photos (created automatically)
DUCK_SPOTS_DIR=duck_spots

# Persisted bot state (game open/closed, review streaks)
STATE_PATH=bot_state.json
